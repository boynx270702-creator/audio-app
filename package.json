{
  "name": "storyverse",
  "version": "1.0.0",
  "private": true,
  "description": "StoryVerse - Reading Platform Enterprise",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:server": "pnpm --filter server build",
    "build:web": "pnpm --filter web build",
    "start": "npm run start:server",
    "start:server": "cd apps/server && npx prisma db push && pnpm start:prod",
    "start:web": "pnpm --filter web start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.0.0",
    "lint-staged": "^15.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
